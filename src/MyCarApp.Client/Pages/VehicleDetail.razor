@page "/vehicles/{Id:int}"
@inject VehicleService VehicleService
@inject LogEntryService LogService
@inject NavigationService NavService

@if (editMode)
{
    <h3>Edit Vehicle</h3>

    <div><label>Nickname</label><input @bind="editVehicle!.Name" /></div>
    <div><label>Make</label><input @bind="editVehicle!.Make" /></div>
    <div><label>Model</label><input @bind="editVehicle!.Model" /></div>
    <div><label>Year</label><input @bind="editVehicle!.Year" type="number" min="1900" max="2100" class="input-short" /></div>
    <div><label>License Plate</label><input @bind="editVehicle!.LicensePlate" /></div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p style="color:red">@errorMessage</p>
    }

    <button @onclick="HandleSaveEdit">Save</button>
    <button class="btn-secondary" @onclick="GoBack">Back</button>
}
else
{
    <h3>@vehicle?.Name</h3>
    <p>@vehicle?.Year @vehicle?.Make @vehicle?.Model | @vehicle?.LicensePlate</p>

    <button @onclick="GoToAddLog">+ Add Log Entry</button>
    <button @onclick="StartEdit">Edit Vehicle</button>
    <button class="btn-secondary" @onclick="GoBack">Back</button>



<!-- New code -->
                        
                            @if (logs != null && logs.Any())
                            {
                                <div class="stats-grid">
                                    <div class="stat-card">
                                        <span class="stat-label">Total KMs</span>
                                        <span class="stat-value">@totalKms.ToString("N0")</span>
                                    </div>
                                    <div class="stat-card">
                                        <span class="stat-label">Fill-ups</span>
                                        <span class="stat-value">@fillUps</span>
                                    </div>
                                    <div class="stat-card">
                                        <span class="stat-label">Total Fuel Cost</span>
                                        <span class="stat-value">$@totalFuelCost.ToString("N2")</span>
                                    </div>
                                    <div class="stat-card">
                                        <span class="stat-label">Total Litres</span>
                                        <span class="stat-value">@totalLitres.ToString("N1") L</span>
                                    </div>
                                    <div class="stat-card">
                                        <span class="stat-label">Avg Consumption</span>
                                        <span class="stat-value">@avgConsumption L/100km</span>
                                    </div>
                                    <div class="stat-card">
                                        <span class="stat-label">Avg Cost/Fill-up</span>
                                        <span class="stat-value">$@avgCostPerFillUp.ToString("N2")</span>
                                    </div>
                                </div>
