@page "/vehicles/{Id:int}"
@inject VehicleService VehicleService
@inject LogEntryService LogService
@inject NavigationManager Nav

@if (editMode)
{
    <h3>Edit Vehicle</h3>

    <div><label>Nickname</label><input @bind="editVehicle!.Name" /></div>
    <div><label>Make</label><input @bind="editVehicle!.Make" /></div>
    <div><label>Model</label><input @bind="editVehicle!.Model" /></div>
    <div><label>Year</label><input @bind="editVehicle!.Year" type="number" min="1900" max="2100" class="input-short" /></div>
    <div><label>License Plate</label><input @bind="editVehicle!.LicensePlate" /></div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p style="color:red">@errorMessage</p>
    }

    <button @onclick="HandleSaveEdit">Save</button>
    <button class="btn-secondary" @onclick="CancelEdit">Back</button>
}
else
{
    <h3>@vehicle?.Name</h3>
    <p>@vehicle?.Year @vehicle?.Make @vehicle?.Model | @vehicle?.LicensePlate</p>

    <button @onclick="GoToAddLog">+ Add Log Entry</button>
    <button @onclick="StartEdit">Edit Vehicle</button>
    <button @onclick="GoToExport">📤 Export</button>
    <button class="btn-secondary" @onclick="GoBack">Back</button>

    @if (logs == null)
    {
        <p>Loading...</p>
    }
    else if (!logs.Any())
    {
        <p>No log entries yet.</p>
    }
    else
    {
        @* Stats Grid *@
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-label">Total KMs</span>
                <span class="stat-value">@totalKms.ToString("N0")</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Fill-ups</span>
                <span class="stat-value">@fillUps</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Total Fuel Cost</span>
                <span class="stat-value">$@totalFuelCost.ToString("N2")</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Total Litres</span>
                <span class="stat-value">@totalLitres.ToString("N1") L</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Avg Consumption</span>
                <span class="stat-value">@avgConsumption L/100km</span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Avg Cost/Fill-up</span>
                <span class="stat-value">$@avgCostPerFillUp.ToString("N2")</span>
            </div>
        </div>

        @* Log Table *@
        <div class="log-table-wrapper">
            <table class="log-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>KM</th>
                        <th>Fuel</th>
                        <th class="expand-col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        <tr class="log-row @(expandedLogId == log.Id ? "expanded" : "")"
                            @onclick="() => ToggleExpand(log.Id)">
                            <td>@log.DateTime.ToString("dd/MM/yy HH:mm")</td>
                            <td>@log.OdometerKm.ToString("N0")</td>
                            <td>@(log.FuelLoaded ? "⛽" : "—")</td>
                            <td class="expand-col">@(expandedLogId == log.Id ? "▲" : "▼")</td>
                        </tr>
                        @if (expandedLogId == log.Id)
                        {
                            <tr class="log-detail-row">
                                <td colspan="4">
                                    @if (editingLogId == log.Id)
                                    {
                                        @* Inline Edit Form *@
                                        <div class="log-detail">
                                            <div>
                                                <label>Date & Time</label>
                                                <input type="datetime-local"
                                                       value="@editDateTimeValue"
                                                       @onchange="OnEditDateTimeChanged" />
                                            </div>
                                            <div>
                                                <label>Odometer (km)</label>
                                                <input @bind="editLog!.OdometerKm" type="number" min="0" />
                                            </div>
                                            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.85rem;">
                                                <input @bind="editLog!.FuelLoaded" type="checkbox" id="editFuelLoaded" />
                                                <label for="editFuelLoaded" style="margin:0; text-transform:none; font-size:1rem;">Fuel loaded?</label>
                                            </div>
                                            @if (editLog!.FuelLoaded)
                                            {
                                                <div>
                                                    <label>Petrol Station</label>
                                                    <input @bind="editLog.PetrolStationName" placeholder="Station name" />
                                                </div>
                                                <div>
                                                    <label>Litres</label>
                                                    <input @bind="editLog.FuelLiters" type="number" step="0.001" />
                                                </div>
                                                <div>
                                                    <label>Price per Litre</label>
                                                    <input @bind="editLog.FuelPricePerLiter" type="number" step="0.001" />
                                                </div>
                                                <div>
                                                    <label>Total Paid</label>
                                                    <input @bind="editLog.FuelTotalPaid" type="number" step="0.01" />
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(editErrorMessage))
                                            {
                                                <p style="color:red">@editErrorMessage</p>
                                            }
                                            <div class="log-detail-actions">
                                                <button @onclick="() => HandleSaveLog(log.Id)"
                                                        @onclick:stopPropagation="true">💾 Save</button>
                                                <button class="btn-secondary" @onclick="CancelEditLog"
                                                        @onclick:stopPropagation="true">Cancel</button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        @* Detail View *@
                                        <div class="log-detail">
                                            @if (log.FuelLoaded)
                                            {
                                                <div class="log-detail-item">
                                                    <span class="log-detail-label">Station</span>
                                                    <span>@(log.PetrolStationName ?? "—")</span>
                                                </div>
                                                <div class="log-detail-item">
                                                    <span class="log-detail-label">Litres</span>
                                                    <span>@log.FuelLiters?.ToString("N3")</span>
                                                </div>
                                                <div class="log-detail-item">
                                                    <span class="log-detail-label">Price/L</span>
                                                    <span>@log.FuelPricePerLiter?.ToString("N3")</span>
                                                </div>
                                                <div class="log-detail-item">
                                                    <span class="log-detail-label">Total Paid</span>
                                                    <span>$@log.FuelTotalPaid?.ToString("N2")</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="log-detail-item">
                                                    <span>No fuel loaded on this entry.</span>
                                                </div>
                                            }
                                            <div class="log-detail-actions">
                                                <button @onclick="() => StartEditLog(log)"
                                                        @onclick:stopPropagation="true">✏️ Edit</button>
                                                @if (confirmDeleteId == log.Id)
                                                {
                                                    <span class="log-detail-label">Are you sure?</span>
                                                    <button class="btn-danger" @onclick="() => ConfirmDelete(log.Id)"
                                                            @onclick:stopPropagation="true">Yes, delete</button>
                                                    <button class="btn-secondary" @onclick="() => confirmDeleteId = null"
                                                            @onclick:stopPropagation="true">Cancel</button>
                                                }
                                                else
                                                {
                                                    <button class="btn-danger" @onclick="() => confirmDeleteId = log.Id"
                                                            @onclick:stopPropagation="true">🗑 Delete</button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Daily Summary *@
        @if (dailySummaries.Any())
        {
            <h3 style="margin-top:1.5rem;">Daily Summary</h3>
            <div class="log-table-wrapper">
                <table class="log-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>KMs</th>
                            <th>Fuel</th>
                            <th>L/100km</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in dailySummaries)
                        {
                            <tr>
                                <td>@day.Date.ToString("dd/MM/yy")</td>
                                <td>@day.KmsDriven.ToString("N0")</td>
                                <td>@(day.FuelLoaded ? $"{day.Litres:N1}L" : "—")</td>
                                <td>@(day.Consumption ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private Vehicle? vehicle;
    private Vehicle? editVehicle;
    private List<LogEntry>? logs;
    private bool editMode = false;
    private string errorMessage = string.Empty;
    private int? expandedLogId = null;
    private int? confirmDeleteId = null;

    // Log entry inline edit
    private int? editingLogId = null;
    private LogEntry? editLog = null;
    private string editDateTimeValue = string.Empty;
    private string editErrorMessage = string.Empty;

    // Stats
    private decimal totalKms = 0;
    private int fillUps = 0;
    private decimal totalFuelCost = 0;
    private decimal totalLitres = 0;
    private string avgConsumption = "—";
    private decimal avgCostPerFillUp = 0;

    // Daily summary
    private List<DailySummary> dailySummaries = new();

    private class DailySummary
    {
        public DateOnly Date { get; set; }
        public decimal MorningKm { get; set; }
        public decimal AfternoonKm { get; set; }
        public decimal KmsDriven { get; set; }
        public bool FuelLoaded { get; set; }
        public decimal Litres { get; set; }
        public string? Consumption { get; set; }
    }

    private void GoToExport() => Nav.NavigateTo($"vehicles/{Id}/export");

    protected override async Task OnInitializedAsync()
    {
        vehicle = (await VehicleService.GetVehiclesAsync()).FirstOrDefault(v => v.Id == Id);
        logs = await LogService.GetLogsAsync(Id);
        CalculateStats();
    }

    private void CalculateStats()
    {
        if (logs == null || !logs.Any()) return;

        var ordered = logs.OrderBy(l => l.DateTime).ToList();

        // Total KMs
        if (ordered.Count >= 2)
            totalKms = ordered.Last().OdometerKm - ordered.First().OdometerKm;
        else
            totalKms = 0;

        // Fuel stats
        var fuelLogs = ordered.Where(l => l.FuelLoaded).ToList();
        fillUps = fuelLogs.Count;
        totalFuelCost = fuelLogs.Sum(l => l.FuelTotalPaid ?? 0);
        totalLitres = fuelLogs.Sum(l => l.FuelLiters ?? 0);
        avgCostPerFillUp = fillUps > 0 ? totalFuelCost / fillUps : 0;

        // Overall consumption using tank method — skip first fill-up
        if (fuelLogs.Count >= 2 && totalKms > 0)
        {
            var litresForCalculation = fuelLogs.Skip(1).Sum(l => l.FuelLiters ?? 0);
            var kmsForCalculation = ordered.Last().OdometerKm - fuelLogs.First().OdometerKm;
            avgConsumption = kmsForCalculation > 0
                ? ((litresForCalculation / kmsForCalculation) * 100).ToString("N1")
                : "—";
        }
        else
        {
            avgConsumption = "—";
        }

        // Daily summaries
        dailySummaries = ordered
            .GroupBy(l => DateOnly.FromDateTime(l.DateTime))
            .Select(g =>
            {
                var dayLogs = g.OrderBy(l => l.DateTime).ToList();
                var morning = dayLogs.First();
                var afternoon = dayLogs.Last();
                var kmsDriven = afternoon.OdometerKm - morning.OdometerKm;
                var fuelLoaded = dayLogs.Any(l => l.FuelLoaded);
                var litres = dayLogs.Where(l => l.FuelLoaded).Sum(l => l.FuelLiters ?? 0);

                string? consumption = null;
                if (fuelLoaded && litres > 0 && kmsDriven > 0)
                    consumption = ((litres / kmsDriven) * 100).ToString("N1") + " L/100km";

                return new DailySummary
                {
                    Date = g.Key,
                    MorningKm = morning.OdometerKm,
                    AfternoonKm = afternoon.OdometerKm,
                    KmsDriven = kmsDriven,
                    FuelLoaded = fuelLoaded,
                    Litres = litres,
                    Consumption = consumption
                };
            })
            .OrderByDescending(d => d.Date)
            .ToList();
    }

    private void ToggleExpand(int logId)
    {
        if (expandedLogId == logId)
        {
            expandedLogId = null;
            editingLogId = null;
            editLog = null;
        }
        else
        {
            expandedLogId = logId;
            editingLogId = null;
            editLog = null;
        }
        confirmDeleteId = null;
        editErrorMessage = string.Empty;
    }

    private void StartEditLog(LogEntry log)
    {
        editingLogId = log.Id;
        editLog = new LogEntry
        {
            Id = log.Id,
            VehicleId = log.VehicleId,
            //DateTime = log.DateTime,
            DateTime = DateTime.SpecifyKind(log.DateTime, DateTimeKind.Unspecified),
            OdometerKm = log.OdometerKm,
            FuelLoaded = log.FuelLoaded,
            FuelLiters = log.FuelLiters,
            FuelPricePerLiter = log.FuelPricePerLiter,
            FuelTotalPaid = log.FuelTotalPaid,
            PetrolStationName = log.PetrolStationName
        };
        editDateTimeValue = log.DateTime.ToString("yyyy-MM-ddTHH:mm");
        editErrorMessage = string.Empty;
    }

    private void CancelEditLog()
    {
        editingLogId = null;
        editLog = null;
        editErrorMessage = string.Empty;
    }

    private void OnEditDateTimeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (!string.IsNullOrEmpty(value) && DateTime.TryParse(value, out var dt))
        {
            editLog!.DateTime = DateTime.SpecifyKind(dt, DateTimeKind.Unspecified);
            editDateTimeValue = value;
        }
    }

    private async Task HandleSaveLog(int logId)
    {
        if (editLog == null) return;

        var success = await LogService.UpdateLogAsync(Id, editLog);
        if (success)
        {
            var index = logs!.FindIndex(l => l.Id == logId);
            if (index >= 0)
                logs[index] = editLog;

            editingLogId = null;
            editLog = null;
            editErrorMessage = string.Empty;
            CalculateStats();
        }
        else
        {
            editErrorMessage = "Failed to save changes.";
        }
    }

    private void StartEdit()
    {
        editVehicle = new Vehicle
        {
            Id = vehicle!.Id,
            Name = vehicle.Name,
            Make = vehicle.Make,
            Model = vehicle.Model,
            Year = vehicle.Year,
            LicensePlate = vehicle.LicensePlate
        };
        editMode = true;
        errorMessage = string.Empty;
    }

    private void CancelEdit()
    {
        editMode = false;
        errorMessage = string.Empty;
    }

    private async Task HandleSaveEdit()
    {
        var success = await VehicleService.UpdateVehicleAsync(editVehicle!);
        if (success)
        {
            vehicle = editVehicle;
            editMode = false;
        }
        else
        {
            errorMessage = "Failed to update vehicle.";
        }
    }

    private async Task ConfirmDelete(int logId)
    {
        var success = await LogService.DeleteLogAsync(Id, logId);
        if (success)
        {
            logs = logs?.Where(l => l.Id != logId).ToList();
            expandedLogId = null;
            confirmDeleteId = null;
            CalculateStats();
        }
    }

    private void GoToAddLog() => Nav.NavigateTo($"vehicles/{Id}/logs/add");
    private void GoBack() => Nav.NavigateTo(Nav.BaseUri);
}
